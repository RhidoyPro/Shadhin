DATABASE_URL=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
FRONTEND_URL=https://shadhin.io
ADMIN_EMAIL=

# Cloudflare R2 (S3-compatible) — file uploads
AWS_BUCKET_NAME=shadhin
AWS_BUCKET_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=
R2_PUBLIC_URL=

# Analytics
NEXT_PUBLIC_MEASUREMENT_ID=
# Microsoft Clarity — free heatmaps + session recordings (clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=
# Meta/Facebook Pixel — retargeting BD users on Facebook/Instagram (business.facebook.com → Events Manager)
NEXT_PUBLIC_META_PIXEL_ID=

# Upstash Redis — rate limiting + feature flags + feed cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random secret to protect cron endpoints — generate with: openssl rand -hex 32
CRON_SECRET=
# OpenAI API key for free text moderation endpoint (optional — falls back to basic check)
OPENAI_API_KEY=
# Set to "true" to enable bot posting (disabled by default)
BOTS_ENABLED=false

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Anthropic API key for automated email support classification (optional)
ANTHROPIC_API_KEY=

# bKash merchant number for manual payments (ticketing, boosts, org badge)
NEXT_PUBLIC_BKASH_NUMBER=